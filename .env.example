# AWS credentials for the Phase 6 cloud benchmark (infra/cloud_bench.sh).
# GitHub Actions (.github/workflows/bench.yml) uses its own repo Secrets — this
# file is only for LOCAL, dev-machine runs.
#
#   cp .env.example .env && $EDITOR .env     # then fill in the real values
#
# .env is gitignored — NEVER commit real credentials. cloud_bench.sh loads it
# automatically. For a manual `terraform -chdir=infra ...` invocation, load it
# yourself first:  set -a; . ./.env; set +a
#
# IMPORTANT: the IAM principal these keys belong to MUST be allowed to use EC2
# (ec2:DescribeImages, RunInstances, {Create,Delete}SecurityGroup, key pairs,
# CreateTags, TerminateInstances). cloud_bench.sh provisions AND destroys 2
# billable resources; an EC2-denied principal (the current
# prabhav.k@codonsystems.com) fails at terraform plan.

# --- Required: long-lived IAM user access key ---------------------------------
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# --- Optional: ONLY for temporary (STS / SSO / assumed-role) credentials ------
# Leave commented for a normal long-lived IAM user access key.
# AWS_SESSION_TOKEN=

# --- Region: drives both the AWS SDK and terraform ----------------------------
# cloud_bench.sh bridges this to TF_VAR_aws_region so the provider matches.
AWS_DEFAULT_REGION=us-east-1

# --- Optional: SSH keypair cloud_bench.sh injects into + connects to the box --
# Defaults to ~/.ssh/id_ed25519 (and .pub) when unset.
# SSH_KEY=$HOME/.ssh/id_ed25519
